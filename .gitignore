# Dependencias
node_modules/

# Compilación
dist/

# Variables privadas y credenciales
.env
.env.local
.env.*.local
!.env.example

# Datos generados por el servidor
data/*
!data/.gitkeep

# Material completo privado (se aloja en Cloudflare R2)
private/course/*
!private/course/.gitkeep
!private/course/README.txt

# Logs y archivos temporales
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
.cache/

# Editores
.vscode/
.idea/
*.swp
*.swo

# Sistema operativo
.DS_Store
Thumbs.db
Desktop.ini

# Railway y herramientas locales
.railway/
.wrangler/
